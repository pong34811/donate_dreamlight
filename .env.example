# Google Sheets API Configuration
# คำแนะนำ: สร้าง OAuth2 Credentials จาก Google Cloud Console
# 1. ไปที่ https://console.cloud.google.com/
# 2. สร้างโปรเจคใหม่หรือเลือกโปรเจคที่มีอยู่
# 3. เปิดใช้งาน Google Sheets API
# 4. ไปที่ Credentials > Create Credentials > OAuth client ID
# 5. เลือก Web application
# 6. เพิ่ม Authorized JavaScript origins: http://localhost:5173
# 7. นำ Client ID มาใส่ด้านล่าง

VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
